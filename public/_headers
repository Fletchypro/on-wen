# Long cache for hashed JS/CSS (Vite build output) – safe to cache 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML – short cache so new deploys are picked up quickly
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Sitemap and robots – cache briefly
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
